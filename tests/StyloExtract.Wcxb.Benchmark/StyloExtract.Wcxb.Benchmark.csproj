<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>StyloExtract.Wcxb.Benchmark</RootNamespace>
    <AssemblyName>StyloExtract.Wcxb.Benchmark</AssemblyName>
    <IsPackable>false</IsPackable>
    <!-- Suppress NU1903 for transitive SQLitePCLRaw.lib.e_sqlite3 via Microsoft.Data.Sqlite -->
    <NoWarn>$(NoWarn);NU1903</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\StyloExtract.Abstractions\StyloExtract.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\StyloExtract.AspNetCore\StyloExtract.AspNetCore.csproj" />
    <ProjectReference Include="..\..\src\StyloExtract.Playwright\StyloExtract.Playwright.csproj" />
  </ItemGroup>
</Project>
